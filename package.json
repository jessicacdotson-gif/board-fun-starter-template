{
  "name": "board-game-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dev:debug": "vite --config vite.config.debug.js",
    "build:debug": "vite build --config vite.config.debug.js",
    "dev:builder": "vite --config vite.config.builder.js",
    "test": "vitest run",
    "pack": "web-pack dist --package-id fun.board.mygame --name \"My Game\" --app-id 00000000-0000-4000-8000-000000000001",
    "pack:debug": "web-pack dist-debug --package-id fun.board.mygamedebug --name \"My Game Glyph Logger\" --app-id 00000000-0000-4000-8000-000000000002",
    "deploy": "npm run build && npm run pack && board-connect install 00000000-0000-4000-8000-000000000001.webapp.zip --launch --timeout 10m"
  },
  "dependencies": {
    "@board.fun/web-sdk": "1.0.0-beta.6",
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "@board.fun/web-pack": "1.0.0-beta.3",
    "pngjs": "^7.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
